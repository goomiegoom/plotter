{
  "name": "plotter",
  "version": "1.0.0",
  "private": true,
  "description": "Prism-style publication figure builder — client-side stats + plotting engine for the dc-runtime UI (Plotter.dc.html).",
  "scripts": {
    "build": "node scripts/build.mjs && node scripts/gen-templates.mjs",
    "build:watch": "node scripts/build.mjs --watch",
    "inline": "node scripts/inline-component.mjs",
    "test": "jest",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "esbuild": "^0.21.5",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.5",
    "typescript": "^5.4.5"
  }
}
